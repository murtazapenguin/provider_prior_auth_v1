# Application
APP_NAME=platform-backend-kit
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production
API_V1_PREFIX=/api/v1

# Database (DocumentDB / MongoDB)
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=platform_backend

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=mongodb://localhost:27017
CELERY_RESULT_DB_NAME=celery_results
# For production with RabbitMQ:
# CELERY_BROKER_URL=amqp://guest:guest@rabbitmq:5672//

# JWT
JWT_SECRET_KEY=change-me-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ISSUER=platform-backend-kit
JWT_AUDIENCE=platform-backend-kit

# Microsoft OAuth2 (MSAL)
MSAL_CLIENT_ID=
MSAL_CLIENT_SECRET=
MSAL_TENANT_ID=
MSAL_AUTHORITY=https://login.microsoftonline.com/{tenant_id}
MSAL_REDIRECT_URI=http://localhost:8000/api/v1/auth/callback/microsoft
MSAL_SCOPES=User.Read

# SAML2
SAML_SP_ENTITY_ID=http://localhost:8000/saml/metadata
SAML_SP_ACS_URL=http://localhost:8000/api/v1/auth/callback/saml
SAML_IDP_METADATA_URL=
SAML_IDP_SSO_URL=
SAML_IDP_CERT_FILE=

# Telemetry / Observability
OTEL_SERVICE_NAME=platform-backend-kit
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_ENABLED=true
PROMETHEUS_ENABLED=true

# Logging
LOG_LEVEL=INFO
LOG_JSON=false

# Multi-tenancy
S3_BUCKET_PREFIX=platform
TENANT_DB_PREFIX=platform_tenant

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=workflow-builder-platform-backend-uploads
S3_APP_PREFIX=my-app-name  # Per-app folder prefix within the shared bucket
S3_PRESIGNED_URL_EXPIRY=3600

# CORS (comma-separated origins for production)
CORS_ALLOWED_ORIGINS=

# Rate Limiting
RATE_LIMIT_AUTHENTICATED=200
RATE_LIMIT_ANONYMOUS=50
RATE_LIMIT_WINDOW_SECONDS=60
