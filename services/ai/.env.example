# Copy to services/ai/.env and fill in real values.
# Never commit services/ai/.env — it is in .gitignore.

AI_SERVICE_TOKEN=dev-token-change-me

# AWS — Bedrock LLM
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Azure Document Intelligence — primary OCR provider
# AZURE_OCR_ENDPOINT=
# AZURE_OCR_SECRET_KEY=

# Langfuse tracing — off by default; set all three to enable
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=

# Penguin SDK
PENGUIN_LLM_PROVIDER=bedrock
PENGUIN_LLM_MODEL=claude-sonnet-4-5
PENGUIN_GUARD_MODEL=claude-haiku-4-5

# Postgres (for ai_call_cache) — same DB as the Next.js service
# DATABASE_URL=postgresql://pa_app:pa_app_dev@localhost:5432/pa_app

LOG_LEVEL=INFO
DEBUG=true

# Phase 6 — reserved. Currently unused on the AI service side: the Next.js side fetches
# FHIR Binary content and sends it to the AI service inline in the request payload, so
# the AI service does not store Epic credentials. Symmetry placeholder only — do not
# populate without an explicit ticket scoping AI-service-direct-FHIR work.
# EPIC_SANDBOX_FHIR_BASE=
# EPIC_SANDBOX_CLIENT_ID=
# FHIR_MODE=mock
