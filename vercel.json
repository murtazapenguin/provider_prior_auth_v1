{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "experimentalServices": {
    "frontend": {
      "routePrefix": "/",
      "framework": "nextjs"
    }
  },
  "crons": [
    {
      "path": "/api/cron/sweep",
      "schedule": "*/5 * * * *"
