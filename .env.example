# Copy this file to .env.local and fill in real values.
# Never commit .env.local — it is in .gitignore.

# Next.js / Prisma
DATABASE_URL=postgresql://pa_app:pa_app_dev@localhost:5432/pa_app?schema=public

# AI service (FastAPI sidecar)
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_TOKEN=dev-token-change-me

# Phase 6 — Epic SMART on FHIR (populate after app registration; see tasks/phase-6-epic-verification.md)
# While registration is pending, FHIR_MODE=mock keeps the build green against fixture FHIR JSON
# and a mock launch flow. Flip to FHIR_MODE=real after EPIC_SANDBOX_CLIENT_ID is set.
EPIC_SANDBOX_FHIR_BASE=https://fhir.epic.com/interconnect-fhir-oauth/api/FHIR/R4
EPIC_SANDBOX_AUTH_BASE=https://fhir.epic.com/interconnect-fhir-oauth/oauth2
# EPIC_SANDBOX_CLIENT_ID=
# EPIC_SANDBOX_REDIRECT_URI=

# AES-256-GCM key for SmartSession token encryption at rest. REQUIRED even in mock mode
# (the encryption boundary stays live in tests). Generate with: openssl rand -base64 32
# APP_TOKEN_ENCRYPTION_KEY=

# FHIR adapter mode: `mock` reads fixture JSON (default during build); `real` calls Epic.
FHIR_MODE=mock

# Phase 6 (T6) — Policy source for findApplicablePolicies / match engine.
# - `demo`       → no publishStatus filter; all seeded policies surface (default).
# - `production` → require Policy.publishStatus='published'; only the 6 hand-curated
#                   policies (backfilled to 'published' by migration 0007) AND any
#                   AI-ingested policies that an admin explicitly published surface.
POLICY_SOURCE=demo
